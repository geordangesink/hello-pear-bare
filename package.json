{
  "name": "hello-pear-bare",
  "version": "0.0.0-rc.0",
  "description": "Pear Runtime CLI boilerplate using Bare with OTA updater support.",
  "private": true,
  "bin": "bin.mjs",
  "upgrade": {
    "production": "pear://<YOUR_PRODUCTION_KEY_HERE>",
    "stage": "pear://<YOUR_STAGE_KEY_HERE>",
    "dev": "pear://<YOUR_DEV_KEY_HERE>"
  },
  "scripts": {
    "format": "prettier . --write",
    "test": "brittle-bare test/index.js",
    "lint": "prettier . --check && lunte",
    "start": "bare bin.mjs --no-updates",
    "make": "node scripts/make.js",
    "make:stage": "node scripts/make.js stage",
    "make:dev": "node scripts/make.js dev",
    "make:darwin-arm64": "node scripts/make.js production darwin-arm64",
    "make:darwin-x64": "node scripts/make.js production darwin-x64",
    "make:linux-arm64": "node scripts/make.js production linux-arm64",
    "make:linux-x64": "node scripts/make.js production linux-x64",
    "make:win32-arm64": "node scripts/make.js production win32-arm64",
    "make:win32-x64": "node scripts/make.js production win32-x64"
  },
  "dependencies": {
    "bare-os": "^3.9.0",
    "bare-path": "^3.0.0",
    "bare-process": "^4.5.0",
    "bare-storage": "^1.1.0",
    "corestore": "^7.9.2",
    "hyperswarm": "^4.17.0",
    "paparam": "^1.10.1",
    "pear-runtime": "^1.1.4",
    "ready-resource": "^1.2.0",
    "which-runtime": "^1.4.0"
  },
  "devDependencies": {
    "bare-build": "^1.0.1",
    "bare-runtime": "^1.29.5",
    "brittle": "^3.19.0",
    "lunte": "^1.2.0",
    "prettier": "^3.6.2",
    "prettier-config-holepunch": "^2.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/holepunchto/hello-pear-bare.git"
  },
  "author": "Holepunch Inc",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/holepunchto/hello-pear-bare/issues"
  }
}
